#!/usr/bin/env python3.11
"""
mac-everything-gui — Everything-like desktop search for macOS
Single binary: starts HTTP server, opens browser, serves search UI.
"""
import os
import sys
import json
import time
import threading
import webbrowser
from http.server import HTTPServer, SimpleHTTPRequestHandler
from urllib.parse import urlparse, parse_qs

# ── Search Engine ──────────────────────────────────────────────
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from importlib.machinery import SourceFileLoader
me_module = SourceFileLoader("mac_everything", os.path.join(os.path.dirname(os.path.abspath(__file__)), "mac-everything")).load_module()

engine = None
engine_lock = threading.Lock()

def get_engine():
    global engine
    with engine_lock:
        if engine is None:
            engine = me_module.MacEverything()
            count, _ = engine.stats()
            if count == 0:
                print("   First run — building full index (this may take a few minutes)...")
                engine.index_path()
            else:
                engine.quick_sync()
        return engine

