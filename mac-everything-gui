const DOC_EXTS = ['pdf', 'doc', 'docx', 'xls', 'xlsx', 'ppt', 'pptx', 'txt', 'md', 'csv', 'pages', 'numbers', 'key'];
const IMG_EXTS = ['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg', 'bmp', 'heic', 'ico', 'psd', 'ai'];
const CODE_EXTS = ['py', 'js', 'ts', 'jsx', 'tsx', 'html', 'css', 'json', 'yaml', 'yml', 'toml', 'sh', 'bash', 'zsh', 'rs', 'go', 'java', 'c', 'cpp', 'h', 'rb', 'php', 'swift', 'kt', 'sql', 'r', 'lua'];

function getIcon(name, ext, isDir) {
  if (isDir) return '📁';
  if (!ext) return '📄';
  ext = ext.replace('.', '').toLowerCase();
  if (IMG_EXTS.includes(ext)) return '🖼️';
  if (CODE_EXTS.includes(ext)) return '💻';
  if (DOC_EXTS.includes(ext)) return '📝';
  if (ext === 'pdf') return '📕';
  if (['mp3', 'wav', 'flac', 'aac', 'm4a'].includes(ext)) return '🎵';
  if (['mp4', 'mov', 'avi', 'mkv', 'webm'].includes(ext)) return '🎬';
  if (['zip', 'tar', 'gz', '7z', 'rar'].includes(ext)) return '📦';
  if (['app', 'dmg', 'pkg'].includes(ext)) return '💿';
  return '📄';
}

function fmtSize(bytes) {
  if (!bytes || bytes === 0) return '';
  const units = ['B', 'KB', 'MB', 'GB', 'TB'];
  let i = 0;
  let s = bytes;
  while (s >= 1024 && i < units.length - 1) { s /= 1024; i++; }
  return s.toFixed(1) + ' ' + units[i];
}

function fmtDate(ts) {
  if (!ts || ts === 0) return '';
  const d = new Date(ts * 1000);
  const pad = n => String(n).padStart(2, '0');
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

async function search(q) {
  if (!q.trim()) {
    tbody.innerHTML = '';
    countEl.textContent = '';
    emptyEl.style.display = 'flex';
    currentResults = [];
    selectedIdx = -1;
    return;
  }

  statusText.textContent = '搜索中...';
  const t0 = performance.now();

  try {
    const ext = currentFilter === 'all' ? '' : '';
    const dirOnly = currentFilter === 'dir';
    let url = `/api/search?q=${encodeURIComponent(q)}&limit=500&hidden=${showHidden ? 1 : 0}`;
    if (dirOnly) url += '&dir=1';

    const resp = await fetch(url);
    const data = await resp.json();

    const elapsed = (performance.now() - t0).toFixed(1);
    currentResults = data.results || [];
    selectedIdx = -1;

    // Filter by type client-side for speed
    let filtered = currentResults;
    if (currentFilter === 'doc') filtered = currentResults.filter(r => DOC_EXTS.includes((r[2]||'').replace('.','').toLowerCase()));
    else if (currentFilter === 'img') filtered = currentResults.filter(r => IMG_EXTS.includes((r[2]||'').replace('.','').toLowerCase()));
    else if (currentFilter === 'code') filtered = currentResults.filter(r => CODE_EXTS.includes((r[2]||'').replace('.','').toLowerCase()));
    else if (currentFilter === 'dir') filtered = currentResults.filter(r => r[5] === 1);

    // Filter hidden files — exclude paths that contain a .-prefixed component
    if (!showHidden) filtered = filtered.filter(r => !r[0].split('/').some(p => p.startsWith('.')));

    renderResults(filtered, elapsed);
    statusTime.textContent = elapsed + 'ms';
  } catch (e) {
    statusText.textContent = '错误: ' + e.message;
  }
}

function renderResults(results, ms) {
  tbody.innerHTML = '';

  if (results.length === 0) {
    emptyEl.style.display = 'flex';
    emptyEl.innerHTML = '<span class="empty-icon">😕</span><span>未找到匹配文件</span>';
    countEl.textContent = '';
    statusText.textContent = '无结果';
    return;
  }

  emptyEl.style.display = 'none';
  countEl.textContent = results.length + ' 个文件';
  statusText.textContent = '就绪';

  for (let i = 0; i < results.length; i++) {
    const [path, name, ext, size, mtime, isDir, rank] = results[i];
    const tr = document.createElement('tr');
    tr.dataset.index = i;
    tr.dataset.path = path;
    tr.innerHTML = `
      <td class="col-icon">${getIcon(name, ext, isDir)}</td>
      <td class="col-name" title="${name}">${name}</td>
      <td class="col-path" title="${path}">${path}</td>
      <td class="col-size">${fmtSize(size)}</td>
      <td class="col-date">${fmtDate(mtime)}</td>
    `;
    tr.addEventListener('click', () => openFile(path, false));
    tr.addEventListener('dblclick', () => openFile(path, false));
    tr.addEventListener('contextmenu', (e) => {
      e.preventDefault();
      openFile(path, true);  // right-click → reveal in Finder
    });
    tbody.appendChild(tr);
  }

  updateSelection();
}

function openFile(path, reveal) {
  statusText.textContent = reveal ? '定位中...' : '打开中...';
  let url = '/api/open?path=' + encodeURIComponent(path);
  if (reveal) url += '&reveal=1';
  fetch(url)
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        statusText.textContent = (reveal ? '📁 已在 Finder 中定位: ' : '✅ 已打开: ') + path.split('/').pop();
      } else {
        statusText.textContent = '❌ 打开失败: ' + (d.error || '未知错误');
      }
    })
    .catch(e => {
      statusText.textContent = '❌ 请求失败: ' + e.message;
    });
}

function updateSelection() {
  document.querySelectorAll('#results-body tr').forEach((tr, i) => {
    tr.classList.toggle('selected', i === selectedIdx);
  });
}

// ── Debounced Search ──
let debounceTimer;
searchEl.addEventListener('input', () => {
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(() => search(searchEl.value), 80);
});

// ── Keyboard ──
document.addEventListener('keydown', e => {
  // ⌘K / ⌘L — focus search
  if ((e.metaKey || e.ctrlKey) && (e.key === 'k' || e.key === 'l')) {
    e.preventDefault();
    searchEl.focus();
    searchEl.select();
    return;
  }

  // ⌘F — focus search
  if ((e.metaKey || e.ctrlKey) && e.key === 'f') {
    e.preventDefault();
    searchEl.focus();
    searchEl.select();
    return;
  }

  if (e.key === 'Escape') {
    if (document.activeElement === searchEl) {
      searchEl.blur();
      searchEl.value = '';
      search('');
    }
    return;
  }

  // Arrow keys — navigate results
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    if (selectedIdx < currentResults.length - 1) selectedIdx++;
    updateSelection();
    scrollToSelected();
    return;
  }
  if (e.key === 'ArrowUp') {
    e.preventDefault();
    if (selectedIdx > 0) selectedIdx--;
    else if (selectedIdx === -1 && currentResults.length > 0) selectedIdx = 0;
    updateSelection();
    scrollToSelected();
    return;
  }

  // Enter — open selected
  if (e.key === 'Enter' && selectedIdx >= 0 && currentResults[selectedIdx]) {
    e.preventDefault();
    const reveal = e.metaKey || e.ctrlKey;  // ⌘+Enter → reveal in Finder
    openFile(currentResults[selectedIdx][0], reveal);
    return;
  }
});

function scrollToSelected() {
  const tr = document.querySelector(`#results-body tr[data-index="${selectedIdx}"]`);
  if (tr) tr.scrollIntoView({ block: 'nearest' });
}

// ── Filters ──
document.querySelectorAll('.filter').forEach(f => {
  f.addEventListener('click', () => {
    document.querySelectorAll('.filter').forEach(ff => ff.classList.remove('active'));
    f.classList.add('active');
    currentFilter = f.dataset.type;
    search(searchEl.value);
  });
});

function toggleHidden() {
  showHidden = !showHidden;
  document.getElementById('hidden-switch').classList.toggle('on', showHidden);
  // Re-search to get server-side hidden filtering
  if (searchEl.value.trim()) {
    search(searchEl.value);
  }
}

// ── Init ──
searchEl.focus();
statusText.textContent = '⏳ 连接服务器中...';

// Poll until server is ready (may take a few seconds on first launch)
let pollCount = 0;
function updateDbTime(ts) {
  if (!ts) return;
  const d = new Date(ts * 1000);
  const pad = n => String(n).padStart(2, '0');
  document.getElementById('db-time').textContent =
    `(数据库更新: ${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())})`;
}
function checkReady() {
  fetch('/api/stats')
    .then(r => r.json())
    .then(d => {
      statusText.textContent = `就绪 · ${d.files.toLocaleString()} 个文件已索引`;
      updateDbTime(d.last_indexed);
      searchEl.focus();
    })
    .catch(() => {
      pollCount++;
      if (pollCount < 60) setTimeout(checkReady, 500);
      else statusText.textContent = '⚠️ 服务器未响应，请重试';
    });
}
checkReady();
// Refresh DB time every 5 minutes
setInterval(() => {
  fetch('/api/stats').then(r => r.json()).then(d => updateDbTime(d.last_indexed)).catch(() => {});
}, 300000);
</script>
</body>
</html>"""

# ── HTTP Handler ───────────────────────────────────────────────
class SearchHandler(SimpleHTTPRequestHandler):
    def log_message(self, format, *args):
        pass  # silent

    def do_GET(self):
        parsed = urlparse(self.path)

        # API: search
        if parsed.path == '/api/search':
            params = parse_qs(parsed.query)
            q = params.get('q', [''])[0]
            limit = int(params.get('limit', ['500'])[0])
            dir_only = 'dir' in params
            exclude_hidden = params.get('hidden', ['1'])[0] == '0'

            try:
                eng = get_engine()
                rows, ms = eng.search(q, limit=limit, dir_only=dir_only, exclude_hidden=exclude_hidden)
                results = [list(r) for r in rows]
                resp = json.dumps({'results': results, 'ms': ms, 'query': q}, ensure_ascii=False).encode()
            except Exception as e:
                resp = json.dumps({'error': str(e), 'results': []}).encode()

            self.send_response(200)
            self.send_header('Content-Type', 'application/json; charset=utf-8')
            self.send_header('Content-Length', len(resp))
            self.end_headers()
            self.wfile.write(resp)
            return

        # API: open file
        if parsed.path == '/api/open':
            import subprocess
            params = parse_qs(parsed.query)
            path = params.get('path', [''])[0]
            reveal = 'reveal' in params
            try:
                cmd = ['open', '-R', path] if reveal else ['open', path]
                result = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
                ok = result.returncode == 0
                resp = json.dumps({'ok': ok, 'error': result.stderr.strip() if not ok else None}, ensure_ascii=False).encode()
            except Exception as e:
                resp = json.dumps({'ok': False, 'error': str(e)}, ensure_ascii=False).encode()

            self.send_response(200)
            self.send_header('Content-Type', 'application/json; charset=utf-8')
            self.send_header('Content-Length', len(resp))
            self.end_headers()
            self.wfile.write(resp)
            return

        # API: stats
        if parsed.path == '/api/stats':
            eng = get_engine()
            count, db_size = eng.stats()
            me_module.format_size(db_size)
            resp = json.dumps({
                'files': count,
                'db_size': db_size,
                'db_size_human': me_module.format_size(db_size),
                'last_indexed': eng.last_indexed,
            }).encode()
            self.send_response(200)
            self.send_header('Content-Type', 'application/json; charset=utf-8')
            self.send_header('Content-Length', len(resp))
            self.end_headers()
            self.wfile.write(resp)
            return

        # Favicon
        if parsed.path == '/favicon.ico':
            self.send_response(204)
            self.end_headers()
            return

        # Serve the main HTML page for everything else
        self.send_response(200)
        self.send_header('Content-Type', 'text/html; charset=utf-8')
        resp = HTML.encode()
        self.send_header('Content-Length', len(resp))
        self.end_headers()
        self.wfile.write(resp)


# ── Main ───────────────────────────────────────────────────────
def main():
    import argparse
    parser = argparse.ArgumentParser(description="mac-everything GUI")
    parser.add_argument("-p", "--port", type=int, default=8765, help="HTTP port (default: 8765)")
    parser.add_argument("--no-browser", action="store_true", help="Don't open browser")
    args = parser.parse_args()

    # Pre-init engine (lightweight, just loads the DB)
    print("🔍 Initializing search engine...")
    eng = get_engine()
    count, db_size = eng.stats()
    print(f"   Index: {count:,} files, {me_module.format_size(db_size)}")

    # Start background periodic sync (every hour)
    fsevent = me_module.FSEventMonitor(eng)
    fsevent.start()
    print("   🔄 Background sync every 1h")

    # Try to start server; if port taken, just open browser to existing instance
    try:
        server = HTTPServer(('127.0.0.1', args.port), SearchHandler)
    except OSError:
        print(f"   Already running on port {args.port}, opening browser...")
        fsevent.stop()
        if not args.no_browser:
            webbrowser.open(f'http://127.0.0.1:{args.port}')
        import signal
        signal.pause()
        return

    print(f"\n🚀 mac-everything GUI running at http://127.0.0.1:{args.port}")
    print(f"   Press Ctrl+C to stop\n")

    if not args.no_browser:
        webbrowser.open(f'http://127.0.0.1:{args.port}')

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n👋 Shutting down...")
        fsevent.stop()
        server.shutdown()

if __name__ == '__main__':
    main()
